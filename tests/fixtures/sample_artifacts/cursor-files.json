{
  "tool_name": "cursor",
  "artifact_patterns": [
    {
      "pattern": ".cursor/rules/*.mdc",
      "type": "directory",
      "description": "Version-controlled project rules for AI behavior customization",
      "file_type": "mdc",
      "status": "stable",
      "is_standard": true,
      "artifact_category": "rules",
      "scope": "project",
      "discovery_method": "glob",
      "glob_pattern": ".cursor/rules/**/*.mdc",
      "path_prefix": ".cursor/rules/",
      "recursive": true,
      "notes": [
        "MDC format: Markdown with YAML frontmatter metadata",
        "Metadata properties: description, globs, alwaysApply",
        "Rule types: Always Apply, Apply Intelligently, Apply to Specific Files, Apply Manually (via @-mentions)",
        "Recommended approach, replaces deprecated .cursorrules"
      ]
    },
    {
      "pattern": ".cursorrules",
      "type": "file",
      "description": "Legacy project-wide AI rules configuration",
      "file_type": "text",
      "status": "deprecated",
      "is_standard": true,
      "artifact_category": "rules",
      "scope": "project",
      "discovery_method": "exact_path",
      "exact_path": ".cursorrules",
      "recursive": false,
      "notes": [
        "Plain text/Markdown format",
        "Located at project root",
        "Deprecated, migration to .cursor/rules/*.mdc recommended"
      ]
    },
    {
      "pattern": "AGENTS.md",
      "type": "file",
      "description": "Simple alternative to structured .cursor/rules for defining AI behavior",
      "file_type": "markdown",
      "status": "stable",
      "is_standard": true,
      "artifact_category": "rules",
      "scope": "project",
      "discovery_method": "exact_path",
      "exact_path": "AGENTS.md",
      "recursive": false,
      "notes": [
        "Plain Markdown (no metadata support)",
        "Project root and subdirectories",
        "Hierarchical application from subdirectories",
        "Simplified option without MDC metadata"
      ]
    }
  ]
}
